{% schema %}
{
  "name": "AI About Page Content",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Bridging the Gap Between AI & Small Business"
    },
    {
      "type": "textarea",
      "id": "hero_subtext",
      "label": "Hero Subtext",
      "default": "We started with a simple observation: the AI revolution is leaving small businesses behind. We're here to change that by making enterprise-grade automation accessible to everyone."
    }
  ],
  "presets": [
    {
      "name": "AI About Page Content"
    }
  ]
}
{% endschema %}

<div class="waa-about-page">
  <!-- Header / Hero -->
  <header class="waa-ab-header">
    <div class="waa-ab-container">
      <h1 class="waa-ab-main-title">{{ section.settings.hero_heading | escape }}</h1>
      <p class="waa-ab-hero-desc">{{ section.settings.hero_subtext | escape }}</p>
    </div>
  </header>

  <div class="waa-ab-container waa-ab-content-stack">
    
    <!-- Section 1: Our Story / Meet the Founder -->
    <section class="waa-ab-item">
      <div class="waa-ab-text">
        <span class="waa-ab-label">Our Story</span>
        <h2 class="waa-ab-title">Human-Centric AI</h2>
        <p class="waa-ab-para">
          Founded in Australia, our agency was built on the belief that AI shouldn't be intimidating or replace humans. Instead, it should act as a force multiplier—removing the "boring bits" of your day so you can focus on the creative, high-value work that grows your business.
        </p>
        <p class="waa-ab-para">
          We don't just hand over a piece of software and walk away. We partner with you to understand your culture, your customers, and your unique challenges to ensure the AI we build actually delivers a return on investment.
        </p>
      </div>
      <div class="waa-ab-visual">
        <div class="waa-ab-image-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Founder / Team Photo</span>
        </div>
      </div>
    </section>

    <div class="waa-ab-divider"></div>

    <!-- Section 2: Core Values Grid -->
    <section class="waa-ab-values">
      <div class="waa-ab-values-header">
        <h2 class="waa-ab-title center">What We Stand For</h2>
      </div>
      
      <div class="waa-ab-grid">
        <div class="waa-ab-value-card">
          <div class="waa-value-icon">01</div>
          <h3>Transparency</h3>
          <p>We are upfront about what AI can and cannot do. No over-promising, just honest solutions that work.</p>
        </div>
        <div class="waa-ab-value-card">
          <div class="waa-value-icon">02</div>
          <h3>Accessibility</h3>
          <p>We speak plain English. Our goal is to demystify technology so you feel empowered, not confused.</p>
        </div>
        <div class="waa-ab-value-card">
          <div class="waa-value-icon">03</div>
          <h3>Security</h3>
          <p>Your data is your most valuable asset. We build with a "security-first" mindset using enterprise-grade protocols.</p>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <div class="waa-ab-bottom-cta">
      <h3>Ready to start your AI journey?</h3>
      <p>We're currently taking on a limited number of new clients for our portfolio program.</p>
      <a href="/pages/contact" class="waa-ab-cta-btn">Book a Discovery Call</a>
    </div>

  </div>
</div>

<style>
  .waa-about-page {
    background-color: #0f0326;
    color: #e2e8f0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .waa-ab-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .waa-ab-header {
    padding: 100px 0 60px;
    text-align: center;
  }

  .waa-ab-main-title {
    color: #ffffff;
    font-size: clamp(2.2rem, 7vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .waa-ab-hero-desc {
    color: #94a3b8;
    font-size: 1.25rem;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .waa-ab-content-stack {
    padding-bottom: 120px;
  }

  .waa-ab-item {
    display: flex;
    flex-direction: column;
    gap: 60px;
    align-items: center;
    padding: 80px 0;
  }

  @media (min-width: 768px) {
    .waa-ab-item {
      flex-direction: row;
    }
  }

  .waa-ab-text {
    flex: 1.2;
  }

  .waa-ab-label {
    display: inline-block;
    color: #2dd4bf;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .waa-ab-visual {
    flex: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 450px;
  }

  .waa-ab-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: #475569;
    font-weight: 500;
    position: relative;
    overflow: hidden;
  }

  .waa-ab-image-placeholder::before {
    content: '';
    position: absolute;
    width: 150%;
    height: 150%;
    background: radial-gradient(circle, rgba(45, 212, 191, 0.05) 0%, transparent 70%);
    top: -25%;
    left: -25%;
  }

  .waa-ab-title {
    color: #ffffff;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 24px;
    line-height: 1.2;
  }

  .waa-ab-title.center {
    text-align: center;
  }

  .waa-ab-para {
    color: #94a3b8;
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .waa-ab-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
    width: 100%;
    margin: 40px 0;
  }

  /* Values Grid */
  .waa-ab-values {
    padding: 60px 0;
  }

  .waa-ab-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  @media (min-width: 768px) {
    .waa-ab-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .waa-ab-value-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 32px;
    border-radius: 20px;
    transition: transform 0.3s ease;
  }

  .waa-ab-value-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.04);
  }

  .waa-value-icon {
    font-family: monospace;
    color: #2dd4bf;
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 16px;
    display: inline-block;
    padding: 4px 10px;
    background: rgba(45, 212, 191, 0.1);
    border-radius: 6px;
  }

  .waa-ab-value-card h3 {
    color: #ffffff;
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .waa-ab-value-card p {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .waa-ab-bottom-cta {
    margin-top: 80px;
    text-align: center;
    padding: 60px 24px;
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(45, 212, 191, 0.05) 0%, rgba(59, 130, 246, 0.05) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .waa-ab-bottom-cta h3 {
    color: #ffffff;
    font-size: 1.75rem;
    margin-bottom: 12px;
  }

  .waa-ab-bottom-cta p {
    color: #94a3b8;
    margin-bottom: 32px;
  }

  .waa-ab-cta-btn {
    display: inline-block;
    padding: 16px 36px;
    background: #ffffff;
    color: #0f0326;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .waa-ab-cta-btn:hover {
    background: #2dd4bf;
    transform: translateY(-2px);
  }
</style>