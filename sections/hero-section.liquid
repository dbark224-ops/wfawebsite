{% schema %}
{
  "name": "AI Agency Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Empowering Australian Small Businesses"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Automate your workflow. Amplify your team."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "We build bespoke AI agents and ChatGPT integrations that act as your digital workforce. Stop doing busywork and start scaling."
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA Text",
      "default": "Book a Discovery Call"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA Link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA Text",
      "default": "Explore Services"
    }
  ],
  "presets": [
    {
      "name": "AI Agency Hero"
    }
  ]
}
{% endschema %}

<section class="waa-hero">
  <!-- Background Glow & Texture -->
  <div class="waa-hero-bg">
    <div class="waa-glow-orb waa-glow-primary"></div>
    <div class="waa-glow-orb waa-glow-secondary"></div>
    <div class="waa-glow-orb waa-glow-tertiary"></div>
    <div class="waa-stardust"></div>
  </div>

  <div class="waa-container">
    <!-- Badge -->
    {% if section.settings.badge_text != blank %}
      <div class="waa-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M19 17v4"></path><path d="M3 5h4"></path><path d="M17 19h4"></path></svg>
        <span>{{ section.settings.badge_text | escape }}</span>
      </div>
    {% endif %}

    <!-- Heading -->
    <h1 class="waa-title">
      {% if section.settings.heading contains 'Amplify' %}
        {{ section.settings.heading | replace: 'Amplify', '<span class="gradient-text">Amplify</span>' }}
      {% else %}
        {{ section.settings.heading | escape }}
      {% endif %}
    </h1>

    <!-- Subtext -->
    {% if section.settings.subtext != blank %}
      <p class="waa-subtext">
        {{ section.settings.subtext | escape }}
      </p>
    {% endif %}

    <!-- Buttons -->
    <div class="waa-btn-group">
      {% if section.settings.primary_cta_text != blank %}
        <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="waa-btn-primary">
          {{ section.settings.primary_cta_text | escape }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      {% endif %}
      
      {% if section.settings.secondary_cta_text != blank %}
        <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="waa-btn-secondary">
          {{ section.settings.secondary_cta_text | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .waa-hero {
    position: relative;
    background-color: #0f0326;
    color: #e2e8f0;
    padding: 120px 24px 160px;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-height: 85vh;
  }

  .waa-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .waa-glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  /* Intense Teal Core */
  .waa-glow-primary {
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(45, 212, 191, 0.45) 0%, rgba(45, 212, 191, 0.15) 35%, transparent 70%);
    opacity: 0.9;
  }

  /* Deep Blue Depth */
  .waa-glow-secondary {
    top: 50%;
    left: 30%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.3) 0%, transparent 75%);
    opacity: 0.7;
    filter: blur(140px);
  }

  /* Purple Ambient Spark */
  .waa-glow-tertiary {
    top: 30%;
    right: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.25) 0%, transparent 70%);
    opacity: 0.6;
    filter: blur(110px);
  }

  .waa-stardust {
    position: absolute;
    inset: 0;
    background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
    opacity: 0.35;
    mix-blend-mode: color-dodge;
  }

  .waa-container {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
  }

  .waa-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    color: #5eead4;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 32px;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .waa-title {
    font-size: clamp(2.8rem, 9vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin-bottom: 28px;
    text-shadow: 0 0 40px rgba(45, 212, 191, 0.3);
  }

  .gradient-text {
    background: linear-gradient(to right, #2dd4bf, #60a5fa, #a855f7);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
  }

  .waa-subtext {
    font-size: 1.25rem;
    color: #ffffff;
    max-width: 650px;
    margin: 0 auto 48px;
    line-height: 1.6;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .waa-btn-group {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .waa-btn-primary {
    background: #ffffff;
    color: #0f0326;
    padding: 18px 36px;
    border-radius: 9999px;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4), 0 0 20px rgba(45, 212, 191, 0.4);
  }

  .waa-btn-primary:hover {
    background: #f8fafc;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 0 0 30px rgba(45, 212, 191, 0.6);
    transform: translateY(-3px);
  }

  .waa-btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    padding: 18px 36px;
    border-radius: 9999px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    transition: all 0.3s ease;
  }

  .waa-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .waa-hero {
      padding: 80px 20px 100px;
    }
    .waa-btn-primary, .waa-btn-secondary {
      width: 100%;
      justify-content: center;
    }
    .waa-glow-primary {
      width: 450px;
      height: 450px;
    }
  }
</style>