{% schema %}
{
  "name": "AI Full Services Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "hero_subtext",
      "label": "Hero Subtext",
      "default": "We provide end-to-end AI implementation for Australian small businesses. From bespoke automation to staff training."
    }
  ],
  "presets": [
    {
      "name": "AI Full Services Page"
    }
  ]
}
{% endschema %}

<div class="waa-services-page">
  <!-- Header / Hero -->
  <header class="waa-sv-header">
    <div class="waa-sv-container">
      <h1 class="waa-sv-main-title">{{ section.settings.hero_heading | escape }}</h1>
      <p class="waa-sv-hero-desc">{{ section.settings.hero_subtext | escape }}</p>
    </div>
  </header>

  <div class="waa-sv-container waa-sv-content-stack">
    
    <!-- Service 1: AI Agents -->
    <section class="waa-sv-item">
      <div class="waa-sv-text">
        <div class="waa-sv-icon-wrap icon-teal">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        </div>
        <h2 class="waa-sv-title">Bespoke AI Agents</h2>
        <p class="waa-sv-para">
          Imagine having a dedicated personal assistant for every employee, running 24/7 without fatigue. We build custom chat-based AI agents embedded with the specific skills, knowledge base, and access needed to perform your company's unique workflows.
        </p>
        <ul class="waa-sv-list">
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Designed specifically for your internal processes.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Integrates directly into the tools you already use.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Maintained and updated by our agency to ensure reliability.</li>
        </ul>
      </div>
      <div class="waa-sv-visual">
        <img
          class="waa-sv-image"
          src="{{ 'bespoke-ai-agents-preview.webp' | asset_url }}"
          alt="Bespoke AI Agents dashboard preview"
          loading="lazy"
        >
      </div>
    </section>

    <div class="waa-sv-divider"></div>

    <!-- Service 2: ChatGPT Integrations -->
    <section class="waa-sv-item waa-sv-reverse">
      <div class="waa-sv-text">
        <div class="waa-sv-icon-wrap icon-blue">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/></svg>
        </div>
        <h2 class="waa-sv-title">ChatGPT Integrations & Apps</h2>
        <p class="waa-sv-para">
          Provide a world-class experience for your customers or securely supercharge your internal team. We build apps that leverage the power of ChatGPT, specifically tuned to your data and products.
        </p>
        <ul class="waa-sv-list">
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> <strong>Public Apps:</strong> Allow consumers to discover and access your products.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> <strong>Internal Apps:</strong> Secure environment for company data processing.</li>
        </ul>
      </div>
      <div class="waa-sv-visual">
        <img
          class="waa-sv-image"
          src="{{ 'chatgpt-integrations-preview.png' | asset_url }}"
          alt="ChatGPT integrations and apps preview"
          loading="lazy"
        >
      </div>
    </section>

    <div class="waa-sv-divider"></div>

    <!-- Service 3: OpenClaw Setup & Hosting -->
    <section class="waa-sv-item">
      <div class="waa-sv-text">
        <div class="waa-sv-icon-wrap icon-orange">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><path d="M10 6h4"/><path d="M6 10v4a2 2 0 0 0 2 2h6"/></svg>
        </div>
        <h2 class="waa-sv-title">OpenClaw Agent Setup & Hosting</h2>
        <p class="waa-sv-para">
          Want custom AI agents running your workflows but don’t want to deal with setup complexity, integrations, or server management? We design, configure, and deploy OpenClaw agents for specific tasks or full multi-agent operations. If you don’t have the time, confidence, or hardware to host it properly, we handle the technical heavy lifting end-to-end.
        </p>
        <ul class="waa-sv-list">
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> OpenClaw agents tailored to one task or multiple business workflows.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Full setup of channels, automations, and tool integrations.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Hosted deployment options for clients without suitable hardware.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Ongoing maintenance, updates, and reliability tuning.</li>
        </ul>
      </div>
      <div class="waa-sv-visual">
        <img
          class="waa-sv-image"
          src="{{ 'openclaw-service-preview.png' | asset_url }}"
          alt="OpenClaw service setup preview"
          loading="lazy"
        >
      </div>
    </section>

    <div class="waa-sv-divider"></div>

    <!-- Service 4: Education -->
    <section class="waa-sv-item waa-sv-reverse">
      <div class="waa-sv-text">
        <div class="waa-sv-icon-wrap icon-purple">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
        </div>
        <h2 class="waa-sv-title">AI Education & Upskilling</h2>
        <p class="waa-sv-para">
          Technology is only as good as the people using it. AI can be overwhelming for employees accustomed to traditional workflows. We bridge the gap with practical, hands-on training.
        </p>
        <ul class="waa-sv-list">
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Tailored courses and workshops for your team.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Demystifying prompt engineering and AI best practices.</li>
          <li><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Fostering a culture of innovation.</li>
        </ul>
      </div>
      <div class="waa-sv-visual">
        <img
          class="waa-sv-image"
          src="{{ 'ai-education-upskilling-preview.png' | asset_url }}"
          alt="AI education and upskilling workshop preview"
          loading="lazy"
        >
      </div>
    </section>

    <!-- Bottom Footer-esque CTA -->
    <div class="waa-sv-bottom-cta">
      <h3>Not sure which solution fits best?</h3>
      <a href="/pages/contact" class="waa-sv-cta-btn">Let's figure it out together</a>
    </div>

  </div>
</div>

<style>
  .waa-services-page {
    background-color: #0f0326;
    color: #e2e8f0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .waa-sv-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .waa-sv-header {
    padding: 100px 0 60px;
    text-align: center;
  }

  .waa-sv-main-title {
    color: #ffffff;
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .waa-sv-hero-desc {
    color: #94a3b8;
    font-size: 1.25rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .waa-sv-content-stack {
    padding-bottom: 120px;
  }

  .waa-sv-item {
    display: flex;
    flex-direction: column;
    gap: 60px;
    align-items: center;
    padding: 80px 0;
  }

  @media (min-width: 768px) {
    .waa-sv-item {
      flex-direction: row;
    }
    .waa-sv-reverse {
      flex-direction: row-reverse;
    }
  }

  .waa-sv-text {
    flex: 1;
  }

  .waa-sv-visual {
    flex: 1;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .waa-sv-blue-tint::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top right, rgba(37, 99, 235, 0.1), transparent);
  }

  .waa-sv-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .waa-sv-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    color: #475569;
    font-weight: 500;
  }

  .waa-sv-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .icon-teal { background: rgba(45, 212, 191, 0.1); color: #2dd4bf; border: 1px solid rgba(45, 212, 191, 0.2); }
  .icon-blue { background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2); }
  .icon-orange { background: rgba(249, 115, 22, 0.1); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.2); }
  .icon-purple { background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.2); }

  .waa-sv-title {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .waa-sv-para {
    color: #94a3b8;
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .waa-sv-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .waa-sv-list li {
    display: flex;
    gap: 12px;
    color: #cbd5e1;
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .waa-sv-list svg.check {
    width: 18px;
    height: 18px;
    color: currentColor; /* Inherits from parent icon wrapper color logic usually */
    flex-shrink: 0;
    margin-top: 3px;
  }
  
  /* Apply specific colors to checks based on parent section if desired, currently uses gray-ish */
  .icon-teal + .waa-sv-title + .waa-sv-para + .waa-sv-list svg.check { color: #2dd4bf; }
  .icon-blue + .waa-sv-title + .waa-sv-para + .waa-sv-list svg.check { color: #3b82f6; }
  .icon-orange + .waa-sv-title + .waa-sv-para + .waa-sv-list svg.check { color: #f97316; }
  .icon-purple + .waa-sv-title + .waa-sv-para + .waa-sv-list svg.check { color: #a855f7; }

  .waa-sv-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
    width: 100%;
  }

  .waa-sv-bottom-cta {
    margin-top: 60px;
    text-align: center;
    padding: 60px 24px;
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .waa-sv-bottom-cta h3 {
    color: #ffffff;
    font-size: 1.5rem;
    margin-bottom: 24px;
  }

  .waa-sv-cta-btn {
    display: inline-block;
    padding: 14px 32px;
    border: 1px solid #2dd4bf;
    color: #2dd4bf;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .waa-sv-cta-btn:hover {
    background: #2dd4bf;
    color: #0f0326;
  }
</style>