{% schema %}
{
  "name": "AI CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to build the future of your business?"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Let's discuss how AI can integrate into your specific workflows. Early projects are highly discounted as we build our portfolio."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Schedule Your Free Discovery Call"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "AI CTA Banner"
    }
  ]
}
{% endschema %}

<section class="waa-cta">
  <div class="waa-cta-container">
    <div class="waa-cta-card">
      <!-- Decorative Glows -->
      <div class="waa-cta-glow waa-glow-1"></div>
      <div class="waa-cta-glow waa-glow-2"></div>
      
      <div class="waa-cta-content">
        <h2 class="waa-cta-heading">{{ section.settings.heading | escape }}</h2>
        <p class="waa-cta-subtext">{{ section.settings.subtext | escape }}</p>
        
        <a href="{{ section.settings.button_link | default: '#' }}" class="waa-cta-btn">
          {{ section.settings.button_text | escape }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .waa-cta {
    padding: 80px 24px;
    background-color: #0f0326;
  }

  .waa-cta-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .waa-cta-card {
    position: relative;
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.15) 0%, rgba(37, 99, 235, 0.15) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    padding: 60px 40px;
    text-align: center;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Glowing Orbs within the card */
  .waa-cta-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
  }

  .waa-glow-1 {
    top: -50px;
    right: -50px;
    width: 250px;
    height: 250px;
    background: rgba(45, 212, 191, 0.2);
  }

  .waa-glow-2 {
    bottom: -50px;
    left: -50px;
    width: 250px;
    height: 250px;
    background: rgba(37, 99, 235, 0.2);
  }

  .waa-cta-content {
    position: relative;
    z-index: 2;
  }

  .waa-cta-heading {
    color: #ffffff;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .waa-cta-subtext {
    color: #cbd5e1;
    font-size: 1.125rem;
    max-width: 650px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .waa-cta-btn {
    display: inline-block;
    background-color: #ffffff;
    color: #0f0326;
    padding: 18px 36px;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .waa-cta-btn:hover {
    background-color: #f1efe7;
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .waa-cta-card {
      padding: 40px 20px;
    }
  }
</style>