{% schema %}
{
  "name": "Real Estate AI Agent",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Packaged AI Agent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Estate AI Agent"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "An always-on operations teammate for modern real estate teams — handling inquiry response, daily market intelligence, and repetitive admin workflows."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Book a demo"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "UI screenshots"
    },
    {
      "type": "image_picker",
      "id": "desktop_screenshot",
      "label": "Desktop screenshot"
    },
    {
      "type": "text",
      "id": "desktop_caption",
      "label": "Desktop caption",
      "default": "Desktop view"
    },
    {
      "type": "image_picker",
      "id": "mobile_screenshot",
      "label": "Mobile screenshot"
    },
    {
      "type": "text",
      "id": "mobile_caption",
      "label": "Mobile caption",
      "default": "Mobile view"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe the feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Estate AI Agent",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Smart inquiry email handling",
            "description": "Monitors inbound email and automatically responds to in-scope property inquiries using your approved property data and latest inspection details."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Human-in-the-loop approvals",
            "description": "If context is missing or a decision is needed, it asks in DM before acting. Example: private inspection requests are checked against calendar availability, then run past the agent before confirmation."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Daily market movement reporting",
            "description": "Scans target postcodes and compares against the previous day to flag newly listed, removed, and price-changed properties in Slack/email reports."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Listing and inspection awareness",
            "description": "Tracks listing updates and inspection changes so responses stay aligned with what is currently live in market."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Action-taking assistant",
            "description": "Supports real web/computer tasks on request — CRM updates, listing portal checks, and operational admin actions while agents are on the move."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Automated social content workflows",
            "description": "Connected to templated API and social media templates so listing and sold content can be produced quickly and consistently."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section class="waa-agent-showcase waa-agent-showcase--{{ section.id }}">
  <div class="waa-agent-container">
    <div class="waa-agent-header">
      {% if section.settings.eyebrow != blank %}
        <p class="waa-agent-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="waa-agent-title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.intro != blank %}
        <p class="waa-agent-intro">{{ section.settings.intro | escape }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a class="waa-agent-cta" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a>
      {% endif %}
    </div>

    <div class="waa-agent-main">
      <div class="waa-agent-top">
        <div class="waa-agent-grid">
          {% for block in section.blocks %}
            <article class="waa-agent-card" {{ block.shopify_attributes }}>
              <h3 class="waa-agent-card-title">{{ block.settings.title | escape }}</h3>
              <p class="waa-agent-card-text">{{ block.settings.description | escape }}</p>
            </article>
          {% endfor %}
        </div>

        <figure class="waa-agent-shot waa-agent-shot--mobile">
          <div class="waa-agent-device-shell waa-agent-device-shell--mobile">
            {% if section.settings.mobile_screenshot != blank %}
              {{ section.settings.mobile_screenshot | image_url: width: 900 | image_tag: class: 'waa-agent-shot-image', loading: 'lazy', alt: section.settings.mobile_caption }}
            {% else %}
              <div class="waa-agent-placeholder">
                <span>Mobile screenshot placeholder</span>
              </div>
            {% endif %}
          </div>
          {% if section.settings.mobile_caption != blank %}
            <figcaption>{{ section.settings.mobile_caption | escape }}</figcaption>
          {% endif %}
        </figure>
      </div>

      <figure class="waa-agent-shot waa-agent-shot--desktop waa-agent-shot--desktop-wide">
        <div class="waa-agent-device-shell">
          {% if section.settings.desktop_screenshot != blank %}
            {{ section.settings.desktop_screenshot | image_url: width: 1800 | image_tag: class: 'waa-agent-shot-image', loading: 'lazy', alt: section.settings.desktop_caption }}
          {% else %}
            <div class="waa-agent-placeholder">
              <span>Desktop screenshot placeholder</span>
            </div>
          {% endif %}
        </div>
        {% if section.settings.desktop_caption != blank %}
          <figcaption>{{ section.settings.desktop_caption | escape }}</figcaption>
        {% endif %}
      </figure>
    </div>
  </div>
</section>

<style>
  .waa-agent-showcase--{{ section.id }} {
    background:
      radial-gradient(circle at 12% 0%, rgba(45, 212, 191, 0.14), transparent 42%),
      radial-gradient(circle at 88% 0%, rgba(96, 165, 250, 0.16), transparent 46%),
      #0f0326;
    padding: 100px 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-header {
    max-width: 860px;
    margin: 0 auto 54px;
    text-align: center;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-eyebrow {
    color: #2dd4bf;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-title {
    color: #ffffff;
    font-size: clamp(2.1rem, 5.2vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-intro {
    color: #94a3b8;
    margin: 0 auto;
    line-height: 1.75;
    font-size: 1.06rem;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-cta {
    display: inline-block;
    margin-top: 24px;
    padding: 12px 22px;
    border-radius: 999px;
    background: linear-gradient(135deg, #2dd4bf, #60a5fa);
    color: #08101f;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 10px 28px rgba(23, 152, 173, 0.35);
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-main {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
    align-items: start;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    align-items: start;
  }

  @media (min-width: 980px) {
    .waa-agent-showcase--{{ section.id }} .waa-agent-top {
      grid-template-columns: 1.2fr 0.8fr;
      gap: 28px;
    }

    .waa-agent-showcase--{{ section.id }} .waa-agent-shot--mobile {
      position: sticky;
      top: 110px;
    }
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-shot {
    margin: 0;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-device-shell {
    background: rgba(7, 10, 18, 0.6);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    padding: 10px;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.34);
    overflow: hidden;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-device-shell--mobile {
    border-radius: 28px;
    max-width: 380px;
    margin: 0 auto;
  }

  @media (min-width: 980px) {
    .waa-agent-showcase--{{ section.id }} .waa-agent-device-shell--mobile {
      max-width: 100%;
    }
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-shot-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-placeholder {
    min-height: 240px;
    border-radius: 12px;
    border: 1px dashed rgba(148, 163, 184, 0.45);
    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px;
    font-size: 0.95rem;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-shot--mobile .waa-agent-placeholder {
    min-height: 460px;
  }

  @media (min-width: 980px) {
    .waa-agent-showcase--{{ section.id }} .waa-agent-shot--mobile .waa-agent-placeholder {
      min-height: 760px;
    }
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-shot--desktop-wide .waa-agent-placeholder {
    min-height: 300px;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-shot figcaption {
    color: #7f91aa;
    font-size: 0.85rem;
    margin-top: 10px;
    text-align: center;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  @media (min-width: 860px) {
    .waa-agent-showcase--{{ section.id }} .waa-agent-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-card {
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px;
    padding: 24px;
    backdrop-filter: blur(8px);
    transition: transform 0.22s ease, border-color 0.22s ease, background-color 0.22s ease;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-card:hover {
    transform: translateY(-3px);
    border-color: rgba(96, 165, 250, 0.4);
    background: rgba(255,255,255,0.06);
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-card-title {
    color: #ffffff;
    font-size: 1.12rem;
    margin: 0 0 8px;
    line-height: 1.45;
  }

  .waa-agent-showcase--{{ section.id }} .waa-agent-card-text {
    color: #9baec3;
    margin: 0;
    line-height: 1.68;
    font-size: 0.97rem;
  }
</style>
